{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProxysVPN",
  "version": "0.1.0",
  "identifier": "com.proxysvpn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProxysVPN",
        "width": 480,
        "height": 720,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/xray", "binaries/tun2socks"],
    "resources": ["binaries/geoip.dat", "binaries/geosite.dat"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "./Entitlements.plist"
    }
  }
}
