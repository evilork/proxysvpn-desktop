<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Tauri WebView (WKWebView) needs JIT for JavaScriptCore -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- WebView allocates executable memory at runtime -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Sidecar binaries (xray, tun2socks) are signed with a different identity
         than the main app; without this Gatekeeper refuses to load them. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
